# Vanta Backend Server Environment Variables
# Copy to .env for local development or configure in your deployment hosting dashboard

# Port number for the Express and Socket.IO server to listen on.
# For production, deployment platforms usually set this automatically.
PORT=3001

# The URL of the client application allowed to make Socket.IO connections.
# For local dev: http://localhost:5173
# For production: https://vanta.app
CLIENT_URL=http://localhost:5173

# The URL of the backend application itself.
# For local dev: http://localhost:3001
# For production: https://api.vanta.app
SERVER_URL=http://localhost:3001

# Node environment setting: 'development' or 'production'.
NODE_ENV=development
